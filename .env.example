# Local API
POUNCE_SENTINEL_ENV=local
POUNCE_SENTINEL_API_BASE_URL=http://localhost:7071/api
POUNCE_SENTINEL_API_KEY=replace-with-local-or-key-vault-secret
POUNCE_SENTINEL_AUDIT_PATH=.pounce-sentinel/verdicts.jsonl
POUNCE_SENTINEL_FEED_STATE_PATH=.pounce-sentinel/feed-state.json
POUNCE_IOC_FEED_URL=
POUNCE_FEED_STALE_AFTER_HOURS=1
POUNCE_FEED_FAILURE_MODE=warn
POUNCE_VULNERABILITY_ACTION=warn
POUNCE_ENABLE_LIVE_LOOKUPS=false
POUNCE_ENABLE_REGISTRY_PROVENANCE=false
# Hosted-feed signing: PEM public key(s) (or file:/path/keys.pem). When set, hosted
# feeds must carry a valid JWS signature (ES256/RS256/EdDSA) or they are rejected.
POUNCE_FEED_SIGNING_PUBLIC_KEYS=
POUNCE_FEED_SIGNATURE_MODE=envelope

# Azure placeholders
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=rg-pounce-sentinel-dev
AZURE_LOCATION=eastus
AZURE_STATIC_WEB_APP_LOCATION=eastus2
AZURE_COSMOS_LOCATION=eastus2
AZURE_FUNCTION_APP_LOCATION=centralus
AZURE_RESOURCE_PREFIX=pouncesentinel

# Azure services created by infra/bicep/main.bicep
AZURE_FUNCTION_APP_NAME=
AZURE_STATIC_WEB_APP_NAME=
AZURE_COSMOS_ACCOUNT_NAME=
AZURE_COSMOS_FEED_STATE_CONTAINER=feed_state
AZURE_KEY_VAULT_NAME=
AZURE_APP_INSIGHTS_NAME=

# Foundry placeholders
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_AGENT_ID=
FOUNDRY_MODEL_DEPLOYMENT_NAME=
AZURE_AI_MODEL_DEPLOYMENT_NAME=
FOUNDRY_TOOL_OPENAPI_URL=
OPENAPI_PROJECT_CONNECTION_NAME=pounce-sentinel-api-key
TOOLBOX_ENDPOINT=

# GitHub placeholders
GITHUB_OWNER=
GITHUB_REPOSITORY=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_SECRET_NAME=pounce-github-private-key

# Teams bot placeholders
TEAMS_BOT_APP_ID=
TEAMS_BOT_PASSWORD_SECRET_NAME=pounce-teams-bot-password
TEAMS_TENANT_ID=00000000-0000-0000-0000-000000000000
